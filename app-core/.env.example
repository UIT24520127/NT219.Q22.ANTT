# =========================================================================
# --- NEXT.JS CONFIG & PORTS ---
# =========================================================================
PORT=3000

# =========================================================================
# --- DATABASE (MariaDB) ---
# =========================================================================
# Sử dụng 127.0.0.1 để tránh lỗi phân giải localhost trên một số máy ảo Linux
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# TUYỆT CHIÊU: Tự động gộp chuỗi kết nối từ các biến lẻ ở trên theo chuẩn Senior!
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

# =========================================================================
# --- OPENBAO KMS CONFIGURATIONS ---
# =========================================================================
BAO_ADDR=http://localhost:8200
BAO_DEV_ROOT_TOKEN_ID=root-token
KMS_TRANSIT_KEY_NAME=music-app-key

# =========================================================================
# --- CLOUDFLARE R2 STORAGE (Object Storage - Bảo mật của Người B) ---
# =========================================================================
# Get these from Cloudflare R2 dashboard: https://dash.cloudflare.com
R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET_NAME=encrypted-audio
R2_REGION=auto
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Endpoint tự động tham chiếu từ Account ID, sửa 1 nơi dùng 2 nơi
R2_ENDPOINT="https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com"

# =========================================================================
# --- mTLS CONFIGURATION (Secure KMS Communication) ---
# =========================================================================
# Path to mTLS certificates directory
# Generate with: ./security/certificates/generate-mtls-certs.sh
MTLS_CERT_DIR=/etc/ssl/certs/drm-kms
MTLS_ENABLED=true

# =========================================================================
# --- AUTHENTICATION (Keycloak - Cấu hình chuẩn đồng nhất drm-realm) ---
# =========================================================================
KEYCLOAK_ISSUER="http://localhost:8080/realms/drm-realm"
KEYCLOAK_CLIENT_ID="backend-api"
KEYCLOAK_SECRET="your-client-secret-here"

# --- Frontend Keycloak Client ---
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=drm-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=backend-api

# =========================================================================
# --- LOCAL FILE STORAGE PATHS ---
# =========================================================================
# Giữ nguyên đường dẫn tương đối (không dùng dấu gạch chéo '/' ở đầu) để chạy được trên cả Windows lẫn Linux
TEMP_UPLOAD_DIR=tmp/audio-uploads
AUDIO_SEGMENTS_DIR=public/audio/segments
AUDIO_MANIFESTS_DIR=public/audio/manifests
AUDIO_METADATA_DIR=tmp/audio/metadata

# =========================================================================
# --- POLICY & ADVANCED SECURITY (Dành cho Tuần 2, 3, 4) ---
# =========================================================================
# --- POLICY (OPA) ---
OPA_URL="http://localhost:8181/v1/data/music_policy"

# --- WIDEVINE CONFIG ---
WIDEVINE_PROVIDER_URL="https://license.widevine.com/cenc/getcontentkey/..."

# --- ECDH KEY WRAPPING (Tuần 3) ---
SERVER_PRIVATE_KEY="your-server-private-key-placeholder"

# --- DPoP & ANTI-REPLAY (Tuần 4) ---
DPOP_MAX_AGE=60
VALKEY_URL="redis://localhost:6379"