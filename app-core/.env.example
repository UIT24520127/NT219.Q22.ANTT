# =========================================================================
# --- NEXT.JS CONFIG & PORTS ---
# =========================================================================
PORT=3000

# =========================================================================
# --- DATABASE (MariaDB) ---
# =========================================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DATABASE_URL="mysql://your_db_user:your_db_password@127.0.0.1:3306/your_db_name"

# =========================================================================
# --- OPENBAO KMS CONFIGURATIONS ---
# =========================================================================
BAO_ADDR=http://localhost:8200
BAO_DEV_ROOT_TOKEN_ID=your-root-token
KMS_TRANSIT_KEY_NAME=music-app-key

# =========================================================================
# --- CLOUDFLARE R2 STORAGE ---
# =========================================================================
R2_ACCOUNT_ID=your_r2_account_id
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name
R2_REGION=auto
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# =========================================================================
# --- AUTHENTICATION (Keycloak) ---
# =========================================================================
KEYCLOAK_ISSUER="http://localhost:8080/realms/your-realm"
KEYCLOAK_CLIENT_ID="your-backend-client-id"
KEYCLOAK_SECRET="your-client-secret-here"

# --- Frontend Keycloak Client ---
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=your-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=your-frontend-client-id

# =========================================================================
# --- LOCAL FILE STORAGE PATHS ---
# =========================================================================
TEMP_UPLOAD_DIR=tmp/audio-uploads
AUDIO_SEGMENTS_DIR=public/audio/segments
AUDIO_MANIFESTS_DIR=public/audio/manifests
AUDIO_METADATA_DIR=tmp/audio/metadata

# =========================================================================
# --- POLICY & ADVANCED SECURITY ---
# =========================================================================
# --- POLICY (OPA) ---
OPA_URL="http://localhost:8181/v1/data/music_policy"

# --- WIDEVINE CONFIG ---
WIDEVINE_PROVIDER_URL="https://license.widevine.com/cenc/getcontentkey/..."

# --- ECDH KEY WRAPPING (Tuần 3) ---
SERVER_PRIVATE_KEY="your-server-private-key-placeholder"

# --- DPoP & ANTI-REPLAY (Tuần 4) ---
DPOP_MAX_AGE=60
VALKEY_URL="redis://localhost:6379"