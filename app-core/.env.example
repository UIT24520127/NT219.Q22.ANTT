# --- DATABASE (MariaDB) ---
# For local host development, we use 'localhost' because port 3306 is mapped to the host.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=drm_system

# --- FILE STORAGE PATHS ---
# Local directories for output segments and manifests
TEMP_UPLOAD_DIR=/tmp/audio-uploads
AUDIO_SEGMENTS_DIR=/tmp/audio/segments
AUDIO_MANIFESTS_DIR=/tmp/audio/manifests
AUDIO_METADATA_DIR=/tmp/audio/metadata

# OpenBao KMS Configurations
BAO_ADDR=http://localhost:8200
BAO_DEV_ROOT_TOKEN_ID=root-token
KMS_TRANSIT_KEY_NAME=music-app-key

# --- AUTHENTICATION (Keycloak) ---
KEYCLOAK_ISSUER="http://localhost:8080/realms/music-realm"
KEYCLOAK_CLIENT_ID="nextjs-client"
KEYCLOAK_SECRET="your-client-secret"

# --- POLICY (OPA) ---
OPA_URL="http://localhost:8181/v1/data/music_policy"

# --- WIDEVINE CONFIG (Người A & Người C cần) ---
# URL của Widevine License Server thật (nếu có) hoặc Proxy URL
WIDEVINE_PROVIDER_URL="https://license.widevine.com/cenc/getcontentkey/..."

# --- ECDH KEY WRAPPING (Tuần 3) ---
# Khóa riêng của Server để thực hiện ECDH với Client
SERVER_PRIVATE_KEY="chuỗi-secret-để-sinh-khóa-server" [cite: 8, 9]

# --- DPoP & ANTI-REPLAY (Tuần 4) ---
# Thời gian hết hạn của DPoP Proof (giây)
DPOP_MAX_AGE=60 [cite: 31, 32]
# Kết nối tới Valkey để lưu jti chống Replay
VALKEY_URL="redis://localhost:6379" [cite: 108]
